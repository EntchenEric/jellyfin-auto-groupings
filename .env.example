# Jellyfin Groupings — Environment Variables
#
# Copy this file to `.env` (or set these as Docker environment variables)
# to configure the application at runtime without using the UI.

# ── API Keys (override config.json values) ──────────────────────────────────
# These take precedence over the values set via the web UI.
# JELLYFIN_API_KEY=your-api-key
# TRAKT_CLIENT_ID=your-trakt-client-id
# TMDB_API_KEY=your-tmdb-api-key
# MAL_CLIENT_ID=your-myanimelist-client-id

# ── Authentication ──────────────────────────────────────────────────────────
# Set a password to enable HTTP Basic Auth on the web UI.
# APP_PASSWORD=your-password

# ── Server ──────────────────────────────────────────────────────────────────
# FLASK_PORT=5000
# FLASK_DEBUG=false
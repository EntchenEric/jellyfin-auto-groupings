# Jellyfin Groupings — environment variables
# Copy to .env and adjust for local development or Docker Compose.
# Values here override config.json for the keys noted below (never written to disk).

# ── Security ────────────────────────────────────────────────────────────────

# Optional HTTP Basic Auth password. When set, protects /api/* routes.
# The UI and static assets load without auth; see README for the security model.
# APP_PASSWORD=

# Comma-separated API paths exempt from CSRF checks (X-Requested-With header).
# Example: /api/health,/api/metrics
# ALLOWED_NON_CSRF_ENDPOINTS=

# ── Flask (development) ───────────────────────────────────────────────────────

# Port for `python app.py` (default: 5000)
# FLASK_PORT=5000

# Enable Flask debug mode (default: false)
# FLASK_DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# ── Gunicorn (Docker / production) ──────────────────────────────────────────

# Worker processes (default: 2)
# GUNICORN_WORKERS=2

# Request timeout in seconds (default: 120)
# GUNICORN_TIMEOUT=120

# ── Scheduler ─────────────────────────────────────────────────────────────────

# Set to 0 to disable the background sync scheduler (default: 1)
# SCHEDULER_ENABLED=1

# Alias: set to 1 to disable scheduler (default: 0)
# DISABLE_SCHEDULER=0

# ── Jellyfin & external APIs ──────────────────────────────────────────────────

# Overrides api_key in config.json (not persisted)
# JELLYFIN_API_KEY=

# Overrides trakt_client_id in config.json
# TRAKT_CLIENT_ID=

# Overrides tmdb_api_key in config.json
# TMDB_API_KEY=

# Overrides mal_client_id in config.json
# MAL_CLIENT_ID=

# AniList GraphQL endpoint (default: https://graphql.anilist.co)
# ANILIST_API_URL=https://graphql.anilist.co

# ── HTTP client retries ───────────────────────────────────────────────────────

# Max retry attempts for outbound HTTP (default: 3)
# NETWORK_RETRY_TOTAL=3

# Exponential backoff factor between retries (default: 1.0)
# NETWORK_RETRY_BACKOFF_FACTOR=1.0

# ── Development helpers ───────────────────────────────────────────────────────

# Port for `python start_virtual_jellyfin.py` mock server (default: 8096)
# VIRTUAL_JF_PORT=8096

# ── E2E tests (tests/test_e2e/) ─────────────────────────────────────────────

# E2E_APP_URL=http://localhost:5005
# E2E_JELLYFIN_URL=http://localhost:8096
# E2E_JELLYFIN_URL_INTERNAL=http://jellyfin:8096
